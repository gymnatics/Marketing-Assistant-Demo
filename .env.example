# Macau Casino Marketing Assistant - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# MODEL ENDPOINTS
# =============================================================================

# Code Model (Qwen2.5-Coder-32B-FP8) - for Coder and K8s agents
# Using custom route with 5min timeout (default KServe route has 30s timeout)
CODE_MODEL_ENDPOINT=https://qwen25-coder-custom-0-marketing-assistant-demo.apps.cluster-qf44v.qf44v.sandbox543.opentlc.com/v1
CODE_MODEL_NAME=qwen25-coder-32b-fp8
CODE_MODEL_TOKEN=<your-token-here>

# Language Model (Qwen3-32B-FP8-dynamic) - for Marketing and Customer agents
# Using custom route with 5min timeout (default KServe route has 30s timeout)
LANG_MODEL_ENDPOINT=https://qwen3-32b-custom-0-marketing-assistant-demo.apps.cluster-qf44v.qf44v.sandbox543.opentlc.com/v1
LANG_MODEL_NAME=qwen3-32b-fp8-dynamic
LANG_MODEL_TOKEN=<your-token-here>

# =============================================================================
# CLUSTER CONFIGURATION
# =============================================================================

CLUSTER_DOMAIN=apps.cluster-qf44v.qf44v.sandbox543.opentlc.com
NAMESPACE=0-marketing-assistant-demo
DEV_NAMESPACE=0-marketing-assistant-demo-dev
PROD_NAMESPACE=0-marketing-assistant-demo-prod

# =============================================================================
# DATABASE
# =============================================================================

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=casino_crm

# =============================================================================
# EMAIL (Optional - simulated by default)
# =============================================================================

EMAIL_MODE=simulate
# RESEND_API_KEY=re_xxxxx

# =============================================================================
# APPLICATION
# =============================================================================

DEBUG=true
LOG_LEVEL=INFO
SUPPORTED_LANGUAGES=en,zh-CN
DEFAULT_LANGUAGE=en
